# ==========================================================
# バックアップ設定ファイル
# このファイルを config.env にコピーして使用してください
# cp config.env.example config.env
# ==========================================================

# ----- 環境識別 -----
# バックアップファイル名・ログに付与される識別子
SERVICE_NAME=app-name            # サービス名 (英数字、ハイフン、アンダースコア)
ENVIRONMENT=production           # production / staging / development

# ----- データベース -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=backup_user
DB_PASS=your_password_here

# ----- バックアップ対象ディレクトリ -----
# Laravelアプリケーションのルートディレクトリ
APP_DIR=/var/www/your-app

# 追加でバックアップするディレクトリ（スペース区切り、不要なら空にする）
EXTRA_BACKUP_DIRS=""

# サーバー設定ファイルのバックアップ（スペース区切り）
CONFIG_BACKUP_DIRS="/etc/nginx /etc/php"

# ----- ローカルバックアップ設定 -----
BACKUP_LOCAL_DIR=/backup         # ローカル保存先
KEEP_GENERATIONS=30              # ローカル保持世代数（古いものから自動削除）

# ----- Cron スケジュール -----
# cron形式: 分 時 日 月 曜日
CRON_MYSQL="0 2 * * *"          # MySQLバックアップ（毎日 2:00）
CRON_FILES="0 3 * * *"          # ファイルバックアップ（毎日 3:00）
CRON_SYNC="0 4 * * *"           # クラウド同期（毎日 4:00）

# ----- ストレージバックエンド -----
# 選択肢: s3 / wasabi / sakura / idrive / local
STORAGE_BACKEND=s3

# ストレージバケット名
STORAGE_BUCKET=your-backup-bucket

# バケット内のプレフィックス（サーバー識別用フォルダ名）
STORAGE_PREFIX=backups/server1

# ----- AWS S3 / S3 互換ストレージ設定 -----
# 公式 CLI (aws s3) を直接実行します。
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1

# S3 互換ストレージの場合のエンドポイント URL
# AWS S3 の場合は空にしてください。
# 例 (Wasabi): https://s3.ap-northeast-1.wasabisys.com
# 例 (Sakura): https://s3.isk01.sakurastorage.jp
# 例 (IDrive): https://n3w.j3.e2.ik.myidrive.com
S3_ENDPOINT_URL=

# セットアップ時にバケットを新規作成するか (y/n)
CREATE_BUCKET=n

# ----- 通知設定 -----
# 通知先メールアドレス
NOTIFY_EMAIL=

# SendGrid (APIを利用する場合)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# チャットツール Webhook URL (Slack, Mattermost 等)
WEBHOOK_URL=

# ----- テストDBリストアチェック -----
# バックアップが正しくリストアできるか定期的に検証するためのDB
TEST_DB_NAME=your_database_test

# テストDBの接続情報 (指定しない場合は本番DBと同じ設定を使用します)
TEST_DB_HOST=
TEST_DB_PORT=
TEST_DB_USER=
TEST_DB_PASS=

CRON_TEST_RESTORE="0 5 * * *"     # テストリストア実行（毎日 5:00）

# ----- ログ設定 -----
LOG_DIR=/var/log/backup

# ----- リストア設定 (MySQLのみ) -----
# リストア時に実行するマスク用SQLファイルのパス
# 例: MASK_SQL_FILE="scripts/mask_data.sql"
MASK_SQL_FILE=""

# リストア開始前に停止し、完了後に起動するサービス名（スペース区切り）
# 例: RESTORE_STOP_SERVICES="nginx php8.3-fpm"
RESTORE_STOP_SERVICES=""
