# ==========================================================
# バックアップ設定ファイル
# このファイルを config.env にコピーして使用してください
# cp config.env.example config.env
# ==========================================================

# ----- 環境識別 -----
# バックアップファイル名・ログに付与される識別子
SERVICE_NAME=app-name            # サービス名 (英数字、ハイフン、アンダースコア)
ENVIRONMENT=production           # production / staging / development

# ----- データベース -----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database
DB_USER=backup_user
DB_PASS=your_password_here

# ----- バックアップ対象ディレクトリ -----
# Laravelアプリケーションのルートディレクトリ
APP_DIR=/var/www/your-app

# 追加でバックアップするディレクトリ（スペース区切り、不要なら空にする）
EXTRA_BACKUP_DIRS=""

# サーバー設定ファイルのバックアップ（スペース区切り）
CONFIG_BACKUP_DIRS="/etc/nginx /etc/php"

# ----- ローカルバックアップ設定 -----
BACKUP_LOCAL_DIR=/backup         # ローカル保存先
KEEP_GENERATIONS=30              # ローカル保持世代数（古いものから自動削除）

# ----- Cron スケジュール -----
# cron形式: 分 時 日 月 曜日
CRON_MYSQL="0 2 * * *"          # MySQLバックアップ（毎日 2:00）
CRON_FILES="0 3 * * *"          # ファイルバックアップ（毎日 3:00）
CRON_SYNC="0 4 * * *"           # クラウド同期（毎日 4:00）

# ----- ストレージバックエンド -----
# 選択肢: b2 / wasabi / s3 / sakura / gdrive / azure / gcs / local
STORAGE_BACKEND=b2

# rclone の設定名（rclone config で設定したリモート名）
STORAGE_REMOTE_NAME=mybackup

# バケット名
STORAGE_BUCKET=your-backup-bucket

# バケット内のプレフィックス（サーバー識別用フォルダ名）
STORAGE_PREFIX=backups/server1

# ----- Backblaze B2 -----
B2_KEY_ID=
B2_APP_KEY=

# ----- Wasabi / AWS S3 互換 -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# Wasabiのエンドポイント（S3の場合は空）
S3_ENDPOINT_URL=

# ----- さくらのオブジェクトストレージ -----
SAKURA_ENDPOINT=https://s3.isk01.sakurastorage.jp

# ----- Google Drive (rclone) -----
# rclone config で設定したGoogle Driveリモート名
GDRIVE_REMOTE_NAME=gdrive
GDRIVE_FOLDER=backups

# ----- Google Workspace (Shared Drive / Team Drive) -----
# Google Workspace の共有ドライブを使用する場合
GWORKSPACE_REMOTE_NAME=gworkspace
GWORKSPACE_DRIVE_ID=               # 共有ドライブのID（URLの末尾部分）
GWORKSPACE_FOLDER=backups

# ----- Azure Blob Storage -----
AZURE_ACCOUNT=
AZURE_KEY=
AZURE_CONTAINER=

# ----- Google Cloud Storage -----
GCS_BUCKET=
GCS_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# ----- IDrive e2 -----
IDRIVE_ACCESS_KEY=
IDRIVE_SECRET_KEY=
IDRIVE_ENDPOINT=https://n3w.j3.e2.ik.myidrive.com

# ----- 通知設定 -----
# 通知先メールアドレス
NOTIFY_EMAIL=

# SendGrid (APIを利用する場合)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# チャットツール Webhook URL (Slack, Mattermost 等)
WEBHOOK_URL=

# ----- テストDBリストアチェック -----
# バックアップが正しくリストアできるか定期的に検証するためのDB
TEST_DB_NAME=your_database_test
CRON_TEST_RESTORE="0 5 * * *"     # テストリストア実行（毎日 5:00）

# ----- サービス側の世代管理 -----
# Google Drive / Google Workspace などはサービス側でファイル更新履歴を保持します。
# USE_SERVICE_VERSIONING=true にすると、ローカル・クラウドの世代削除をスキップし
# サービス側のバージョン履歴に委ねます。
# 対象バックエンド: gdrive, gworkspace
USE_SERVICE_VERSIONING=false

# ----- ログ設定 -----
LOG_DIR=/var/log/backup

# ----- リストア設定 (MySQLのみ) -----
# リストア時に実行するマスク用SQLファイルのパス
# 例: MASK_SQL_FILE="scripts/mask_data.sql"
MASK_SQL_FILE=""

# リストア開始前に停止し、完了後に起動するサービス名（スペース区切り）
# 例: RESTORE_STOP_SERVICES="nginx php8.3-fpm"
RESTORE_STOP_SERVICES=""
